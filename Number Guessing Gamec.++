#include <iostream>
#include <cstdlib>
#include <ctime>
using namespace std;

int main() {

    srand(time(0));

    int secret = rand() % 100 + 1;
    int guess;

    do {

        cout << "Guess number (1-100): ";
        cin >> guess;

        if(guess > secret)
            cout << "Too high!\n";
        else if(guess < secret)
            cout << "Too low!\n";

    } while(guess != secret);

    cout << "You Win!";

    return 0;
}
